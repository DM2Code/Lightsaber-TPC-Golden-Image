<?xml version="1.0" encoding="utf-8"?>
<unattend xmlns="urn:schemas-microsoft-com:unattend">

  <!--
  ═══════════════════════════════════════════════════════════════════════
   TPC Deployment  –  unattend.xml
   Purpose : Skip all OOBE screens with US locale defaults.
             No Microsoft account, no Wi-Fi setup, no telemetry opt-in.
             Sets solid navy-blue desktop background for all users.

   BEFORE DEPLOYING:
     1. Update <ComputerName> if the PC name changes from Lightsaber-TPC.
     2. Confirm <TimeZone> matches the target region.

   Placement (handled automatically by Deploy-TPC.cmd):
     W:\Windows\Panther\unattend.xml
  ═══════════════════════════════════════════════════════════════════════
  -->

  <!-- ──────────────────────────────────────────────────────────────────
       specialize pass
       Runs once before first boot, after hardware is detected.
       Good for machine-level settings (name, time zone).
  ─────────────────────────────────────────────────────────────────────── -->
  <settings pass="specialize">
    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <!-- Use * to let Windows generate a random suffix (e.g. TPC-3F2A).
           Replace with a fixed string for a static hostname.           -->
      <ComputerName>Lightsaber-TPC</ComputerName>
      <TimeZone>Pacific Standard Time</TimeZone>
    </component>
  </settings>

  <!-- ──────────────────────────────────────────────────────────────────
       oobeSystem pass
       Controls every screen the OOBE wizard would normally show.
  ─────────────────────────────────────────────────────────────────────── -->
  <settings pass="oobeSystem">

    <!-- Locale and keyboard layout -->
    <component name="Microsoft-Windows-International-Core"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">
      <InputLocale>en-US</InputLocale>
      <SystemLocale>en-US</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UILanguageFallback>en-US</UILanguageFallback>
      <UserLocale>en-US</UserLocale>
    </component>

    <!-- Shell setup: suppress OOBE screens + create local admin account -->
    <component name="Microsoft-Windows-Shell-Setup"
               processorArchitecture="amd64"
               publicKeyToken="31bf3856ad364e35"
               language="neutral"
               versionScope="nonSxS"
               xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">

      <OOBE>
        <!-- Skip the Microsoft EULA page -->
        <HideEULAPage>true</HideEULAPage>

        <!-- Skip "Create an account" screen (account is defined below) -->
        <HideLocalAccountScreen>true</HideLocalAccountScreen>

        <!-- Skip OEM registration / promotional screen -->
        <HideOEMRegistrationScreen>true</HideOEMRegistrationScreen>

        <!-- Skip Microsoft account / sign-in with Microsoft prompts -->
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>

        <!-- Skip Wi-Fi / network connection setup -->
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>

        <!-- Classify this machine as a Work network location -->
        <NetworkLocation>Work</NetworkLocation>

        <!-- 3 = decline automatic protection settings and diagnostic sharing
             (i.e. "don't share my experience with Microsoft")            -->
        <ProtectYourPC>3</ProtectYourPC>

        <!-- Bypass the machine-level OOBE wizard entirely -->
        <SkipMachineOOBE>true</SkipMachineOOBE>

        <!-- Bypass per-user OOBE on first logon -->
        <SkipUserOOBE>true</SkipUserOOBE>
      </OOBE>

      <UserAccounts>
        <LocalAccounts>
          <LocalAccount wcm:action="add">
            <Password>
              <Value>L1ghts@b3r</Value>
              <PlainText>true</PlainText>
            </Password>
            <DisplayName>AlconUser</DisplayName>
            <Group>Administrators</Group>
            <Name>AlconUser</Name>
          </LocalAccount>
        </LocalAccounts>
      </UserAccounts>

      <AutoLogon>
        <Password>
          <Value>L1ghts@b3r</Value>
          <PlainText>true</PlainText>
        </Password>
        <Enabled>true</Enabled>
        <LogonCount>2</LogonCount>
        <Username>AlconUser</Username>
      </AutoLogon>

      <FirstLogonCommands>
        <!-- <SynchronousCommand wcm:action="add">
          <Order>3</Order>
          <Description>Create Lightsaber Panel desktop shortcut</Description>
          <CommandLine>powershell.exe -ExecutionPolicy Bypass -Command "$ws = New-Object -ComObject WScript.Shell; $s = $ws.CreateShortcut([Environment]::GetFolderPath('Desktop') + '\Lightsaber Panel.lnk'); $s.TargetPath = 'C:\Program Files\Alcon Research\Lightsaber Panel\Lightsaber Panel.exe'; $s.Save()"</CommandLine>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand> -->
        
        <SynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Description>Set display resolution to 1152x864</Description>
          <CommandLine>C:\Windows\Setup\Scripts\QRes.exe /X:1152 /Y:864</CommandLine>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>     

        <SynchronousCommand wcm:action="add">
          <Order>2</Order>
          <Description>Set navy blue background for AlconUser</Description>
          <CommandLine>powershell.exe -ExecutionPolicy Bypass -File "C:\Windows\Setup\Scripts\SetBackground-CurrentUser.ps1"</CommandLine>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>
        
        <SynchronousCommand wcm:action="add">
          <Order>4</Order>
          <Description>Enable Keyboard Filter after deployment</Description>
          <CommandLine>powershell.exe -ExecutionPolicy Bypass -File "C:\Windows\Setup\Scripts\Enable-KeyboardFilter.ps1"</CommandLine>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>

        <SynchronousCommand wcm:action="add">
          <Order>5</Order>
          <Description>Enable UWF and protect C drive after deployment</Description>
          <CommandLine>cmd /c uwfmgr.exe filter enable</CommandLine>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>
        
        <SynchronousCommand wcm:action="add">
          <Order>6</Order>
          <Description>Reboot after OOBE to apply background</Description>
          <CommandLine>shutdown /r /t 5</CommandLine>
          <RequiresUserInput>false</RequiresUserInput>
        </SynchronousCommand>
      </FirstLogonCommands>

    </component>
  </settings>

</unattend>